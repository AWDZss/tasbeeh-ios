{
  "name": "tasbeeh-capacitor",
  "version": "1.0.0",
  "private": true,
  "description": "Offline Tasbeeh app packaged for iOS with Capacitor.",
  "scripts": {
    "sync:web": "node scripts/sync-web.mjs",
    "build": "npm run sync:web",
    "dev": "node scripts/dev-server.mjs",
    "serve": "node scripts/dev-server.mjs",
    "cap:copy": "npm run build && cap copy ios",
    "cap:sync": "npm run build && cap sync ios"
  },
  "dependencies": {
    "@capacitor/core": "8.4.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.1",
    "@capacitor/preferences": "8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "http-server": "^14.1.1"
  }
}
